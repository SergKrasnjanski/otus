{
  "info": {
    "name": "JWT API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "REST API с JWT-авторизацией.\n\nПорядок работы:\n1. Auth → Register (USER)\n2. Auth → Login as USER  → токен сохранится в {{userToken}}\n3. Auth → Login as ADMIN → токен сохранится в {{adminToken}}\n4. Далее — любые запросы\n\nФормат ошибок (RFC 7807 ProblemDetail):\n{\n  \"title\": \"Not Found\",\n  \"status\": 404,\n  \"detail\": \"...\"\n}"
  },
  "variable": [
    { "key": "baseUrl",     "value": "http://localhost:8080" },
    { "key": "userToken",   "value": "" },
    { "key": "adminToken",  "value": "" },
    { "key": "taskId",      "value": "1" },
    { "key": "categoryId",  "value": "1" },
    { "key": "userId",      "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (USER)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Регистрация нового пользователя. Роль всегда USER.\nАдмин создаётся автоматически при старте: username=admin, password=admin123"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 201 Created\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Вернул token\", () => pm.expect(pm.response.json().token).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as USER",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Токен автоматически сохранится в переменную {{userToken}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 200 OK\", () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test(\"Вернул token\", () => pm.expect(json.token).to.be.a('string'));",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('userToken', json.token);",
                  "    console.log('userToken сохранён');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as ADMIN",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Токен автоматически сохранится в переменную {{adminToken}}.\nАдмин создаётся приложением при первом запуске (DataInitializer)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 200 OK\", () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test(\"Вернул token\", () => pm.expect(json.token).to.be.a('string'));",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('adminToken', json.token);",
                  "    console.log('adminToken сохранён');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Ошибки",
          "item": [
            {
              "name": "[400] Register — пустой username",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"\",\n  \"email\": \"valid@example.com\",\n  \"password\": \"password123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "auth", "register"]
                },
                "description": "Нарушение @NotBlank на поле username → 400 Validation Failed"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 400 Bad Request\", () => pm.response.to.have.status(400));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Validation Failed\", () => pm.expect(json.title).to.eql('Validation Failed'));",
                      "pm.test(\"detail содержит 'username'\", () => pm.expect(json.detail).to.include('username'));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[400] Register — невалидный email",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"bob\",\n  \"email\": \"not-an-email\",\n  \"password\": \"password123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "auth", "register"]
                },
                "description": "Нарушение @Email на поле email → 400 Validation Failed"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 400 Bad Request\", () => pm.response.to.have.status(400));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Validation Failed\", () => pm.expect(json.title).to.eql('Validation Failed'));",
                      "pm.test(\"detail содержит 'email'\", () => pm.expect(json.detail).to.include('email'));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[400] Register — пароль короче 6 символов",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"bob\",\n  \"email\": \"bob@example.com\",\n  \"password\": \"123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "auth", "register"]
                },
                "description": "Нарушение @Size(min=6) на поле password → 400 Validation Failed"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 400 Bad Request\", () => pm.response.to.have.status(400));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Validation Failed\", () => pm.expect(json.title).to.eql('Validation Failed'));",
                      "pm.test(\"detail содержит 'password'\", () => pm.expect(json.detail).to.include('password'));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[400] Register — дубликат username",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"other@example.com\",\n  \"password\": \"password123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "auth", "register"]
                },
                "description": "Предварительно: выполнить «Register (USER)» (username=alice).\nИмя уже занято → 400 Bad Request"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 400 Bad Request\", () => pm.response.to.have.status(400));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Bad Request\", () => pm.expect(json.title).to.eql('Bad Request'));",
                      "pm.test(\"detail: Username is already taken\", () => pm.expect(json.detail).to.eql('Username is already taken'));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[400] Register — дубликат email",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"alice2\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "auth", "register"]
                },
                "description": "Предварительно: выполнить «Register (USER)» (email=alice@example.com).\nEmail уже занят → 400 Bad Request"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 400 Bad Request\", () => pm.response.to.have.status(400));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Bad Request\", () => pm.expect(json.title).to.eql('Bad Request'));",
                      "pm.test(\"detail: Email is already in use\", () => pm.expect(json.detail).to.eql('Email is already in use'));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[401] Login — неверный пароль",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"wrongpassword\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/auth/login",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "auth", "login"]
                },
                "description": "Предварительно: выполнить «Register (USER)».\nНеверный пароль → 401 Unauthorized"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 401 Unauthorized\", () => pm.response.to.have.status(401));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Unauthorized\", () => pm.expect(json.title).to.eql('Unauthorized'));",
                      "pm.test(\"detail: Invalid username or password\", () => pm.expect(json.detail).to.eql('Invalid username or password'));"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Tasks",
      "description": "Доступно USER и ADMIN. Пользователь видит только свои задачи; ADMIN видит все.",
      "item": [
        {
          "name": "Get all tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "status", "value": "OPEN", "disabled": true }
              ]
            },
            "description": "Параметр status необязателен. Значения: OPEN, IN_PROGRESS, DONE.\nСтрока с параметром status отключена — включите при необходимости."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 200 OK\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Вернул page с content\", () => {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('content');",
                  "    pm.expect(json.content).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get all tasks (фильтр по статусу)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?status=OPEN",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [{ "key": "status", "value": "OPEN" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 200 OK\", () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get task by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "description": "{{taskId}} заполняется автоматически после Create task"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 200 OK\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Есть поле id\", () => pm.expect(pm.response.json().id).to.exist);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Купить молоко\",\n  \"description\": \"2 литра, 3.2%\",\n  \"status\": \"OPEN\",\n  \"categoryId\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"]
            },
            "description": "После успешного создания ID задачи сохраняется в {{taskId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 201 Created\", () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.test(\"Есть поле id\", () => pm.expect(json.id).to.exist);",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('taskId', json.id);",
                  "    console.log('taskId сохранён: ' + json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Купить молоко\",\n  \"description\": \"Обновлено\",\n  \"status\": \"IN_PROGRESS\",\n  \"categoryId\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 200 OK\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Статус задачи обновлён\", () => {",
                  "    pm.expect(pm.response.json().status).to.eql('IN_PROGRESS');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Статус 204 No Content\", () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "Ошибки",
          "item": [
            {
              "name": "[401] Get tasks — без токена",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/tasks",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "tasks"]
                },
                "description": "Запрос без заголовка Authorization → Spring Security возвращает 401"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 401 Unauthorized\", () => pm.response.to.have.status(401));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Unauthorized\", () => pm.expect(json.title).to.eql('Unauthorized'));",
                      "pm.test(\"status в теле: 401\", () => pm.expect(json.status).to.eql(401));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[401] Get tasks — невалидный токен",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer invalid.token.value" }],
                "url": {
                  "raw": "{{baseUrl}}/api/tasks",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "tasks"]
                },
                "description": "Токен сломан → JWT-фильтр не может его распарсить → 401"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 401 Unauthorized\", () => pm.response.to.have.status(401));",
                      "pm.test(\"title: Unauthorized\", () => pm.expect(pm.response.json().title).to.eql('Unauthorized'));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[404] Get task — несуществующий ID",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/tasks/999999",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "tasks", "999999"]
                },
                "description": "Задача с таким ID не существует → ResourceNotFoundException → 404"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 404 Not Found\", () => pm.response.to.have.status(404));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Not Found\", () => pm.expect(json.title).to.eql('Not Found'));",
                      "pm.test(\"status в теле: 404\", () => pm.expect(json.status).to.eql(404));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[403] Get task — чужая задача",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "tasks", "{{taskId}}"]
                },
                "description": "Предварительно:\n1. Создать задачу от имени alice ({{taskId}} заполнится)\n2. В {{userToken}} подставить токен ДРУГОГО пользователя (bob)\n\nПользователь пытается получить чужую задачу → ForbiddenException → 403"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 403 Forbidden\", () => pm.response.to.have.status(403));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Forbidden\", () => pm.expect(json.title).to.eql('Forbidden'));",
                      "pm.test(\"status в теле: 403\", () => pm.expect(json.status).to.eql(403));"
                    ]
                  }
                }
              ]
            },
            {
              "name": "[400] Create task — пустой title",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{userToken}}" },
                  { "key": "Content-Type",  "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"title\": \"\",\n  \"description\": \"desc\",\n  \"status\": \"OPEN\",\n  \"categoryId\": null\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/tasks",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "tasks"]
                },
                "description": "Нарушение @NotBlank(message=\"Task title is required\") → 400 Validation Failed"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Статус 400 Bad Request\", () => pm.response.to.have.status(400));",
                      "var json = pm.response.json();",
                      "pm.test(\"title: Validation Failed\", () => pm.expect(json.title).to.eql('Validation Failed'));",
                      "pm.test(\"detail: Task title is required\", () => pm.expect(json.detail).to.include('Task title is required'));"
                    ]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get all categories",
